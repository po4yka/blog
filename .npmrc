# Explicit registry prevents accidental resolution through a proxy (e.g. safetycli.com)
# that caused uuid v14 and qs to resolve from a non-npmjs source.
registry=https://registry.npmjs.org/

# eslint-plugin-react-hooks@7 and typescript-eslint@8 don't yet support
# eslint@10 / typescript@6. Remove once upstream catches up.
legacy-peer-deps=true
