---
// Blog figure with art-direction variants (desktop/mobile × light/dark)
// and per-variant format conversion (AVIF/WebP/PNG) via astro:assets.
// Callers pass ImageMetadata directly (via a generated manifest module)
// because import.meta.glob does not resolve when this component renders
// as a slotted child of a React island in Astro 6.

import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Variants {
  desktopLight: ImageMetadata;
  desktopDark: ImageMetadata;
  mobileLight: ImageMetadata;
  mobileDark: ImageMetadata;
}

interface Props {
  variants: Variants;
  alt: string;
  caption?: string;
}

const { variants, alt, caption } = Astro.props;

const FORMATS = ["avif", "webp", "png"] as const;

const ART_DIRECTIONS: Array<{
  media: string;
  src: ImageMetadata;
  theme: "dark" | "light";
  viewport: "mobile" | "desktop";
}> = [
  {
    media: "(prefers-color-scheme: dark) and (max-width: 640px)",
    src: variants.mobileDark,
    theme: "dark",
    viewport: "mobile",
  },
  {
    media: "(max-width: 640px)",
    src: variants.mobileLight,
    theme: "light",
    viewport: "mobile",
  },
  {
    media: "(prefers-color-scheme: dark)",
    src: variants.desktopDark,
    theme: "dark",
    viewport: "desktop",
  },
];

const sources = await Promise.all(
  ART_DIRECTIONS.flatMap((direction) =>
    FORMATS.map(async (format) => {
      const processed = await getImage({
        src: direction.src,
        format,
        quality: 85,
      });
      return {
        srcset: processed.src,
        type: `image/${format}` as const,
        media: direction.media,
        theme: direction.theme,
        viewport: direction.viewport,
      };
    }),
  ),
);

const fallback = await getImage({ src: variants.desktopLight, format: "png" });
---

<figure class="blog-figure">
  <picture data-theme-aware>
    {sources.map((source) => (
      <source
        srcset={source.srcset}
        type={source.type}
        media={source.media}
        data-theme={source.theme}
        data-viewport={source.viewport}
      />
    ))}
    <img
      src={fallback.src}
      alt={alt}
      width={fallback.attributes.width}
      height={fallback.attributes.height}
      loading="lazy"
      decoding="async"
    />
  </picture>
  <script is:inline>
    {
      // Runs synchronously as the parser hits it — before the browser resolves
      // the preceding picture's sources against media queries. Eliminates the
      // wrong-theme flash the hoisted module script caused on first paint.
      const script = document.currentScript;
      let picture = script ? script.previousElementSibling : null;
      while (picture && picture.tagName !== "PICTURE") {
        picture = picture.previousElementSibling;
      }
      if (picture && picture.dataset.themeSynced !== "1") {
        const siteDark = document.documentElement.classList.contains("dark");
        picture.querySelectorAll("source[data-theme]").forEach((src) => {
          const theme = src.dataset.theme;
          const viewport = src.dataset.viewport;
          if (theme !== "dark" && theme !== "light") return;
          const matches = theme === "dark" ? siteDark : !siteDark;
          src.setAttribute(
            "media",
            matches ? (viewport === "mobile" ? "(max-width: 640px)" : "all") : "not all",
          );
        });
        picture.dataset.themeSynced = "1";
      }
    }
  </script>
  {caption && <figcaption><em>{caption}</em></figcaption>}
</figure>

<script is:inline>
  {
    // Runs once per page (same inline body on every figure is fine — it only
    // installs observers behind a window sentinel and then re-runs sync).
    const syncBlogFigures = () => {
      const siteDark = document.documentElement.classList.contains("dark");
      document.querySelectorAll("picture[data-theme-aware]").forEach((picture) => {
        picture.querySelectorAll("source[data-theme]").forEach((src) => {
          const theme = src.dataset.theme;
          const viewport = src.dataset.viewport;
          if (theme !== "dark" && theme !== "light") return;
          const matches = theme === "dark" ? siteDark : !siteDark;
          src.setAttribute(
            "media",
            matches ? (viewport === "mobile" ? "(max-width: 640px)" : "all") : "not all",
          );
        });
        picture.dataset.themeSynced = "1";
      });
    };

    if (!window.__blogFigureSyncInstalled) {
      window.__blogFigureSyncInstalled = true;
      new MutationObserver(syncBlogFigures).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
      });
      document.addEventListener("astro:after-swap", syncBlogFigures);
    }
    syncBlogFigures();
  }
</script>
