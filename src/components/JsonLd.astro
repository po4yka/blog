---
import type { BlogPostData } from "@/types";

interface Props {
  isHomePage?: boolean;
  blogPost?: BlogPostData;
  slug?: string;
  lang?: string;
}

const { isHomePage = false, blogPost, slug, lang = "en" } = Astro.props;

const SITE_URL = "https://po4yka.dev";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${SITE_URL}/#person`,
  name: "Nikita Pochaev",
  alternateName: "po4yka",
  url: SITE_URL,
  jobTitle: "AI Engineer & Senior Mobile Developer",
  description:
    "AI Engineer and Senior Mobile Developer specializing in Android and Kotlin Multiplatform Mobile (KMM). Architects KMM shared modules with 60%+ code sharing, builds release automation pipelines, and integrates ML-powered features — from LLM-driven product flows to on-device inference — into production mobile apps.",
  knowsAbout: [
    "AI/ML Engineering",
    "LLM Integration",
    "Machine Learning",
    "Android",
    "iOS",
    "Kotlin Multiplatform",
    "MobileOps",
    "Jetpack Compose",
    "SwiftUI",
    "CI/CD",
    "Gradle",
    "Fastlane",
    "Mobile Architecture",
    "Release Automation",
  ],
  hasOccupation: {
    "@type": "Occupation",
    name: "AI Engineer & Senior Mobile Developer",
    occupationLocation: { "@type": "Country", name: "Remote" },
    skills:
      "Kotlin, Swift, Jetpack Compose, SwiftUI, Kotlin Multiplatform, Gradle, Fastlane, CI/CD, Mobile Architecture, Python, PyTorch, LLM integration, on-device ML",
  },
  makesOffer: {
    "@type": "Offer",
    itemOffered: {
      "@type": "Service",
      name: "AI & Mobile Engineering Consulting",
      description:
        "KMM architecture design, MobileOps pipeline setup, Gradle build optimization, and ML feature integration consulting for mobile product teams.",
    },
  },
  sameAs: [
    "https://github.com/po4yka",
    "https://linkedin.com/in/po4yka",
    "https://t.me/po4yka",
  ],
};

const websiteSchema = isHomePage
  ? {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "Nikita Pochaev",
      url: SITE_URL,
      description:
        "AI Engineer and Senior Mobile Developer — Android, Kotlin Multiplatform Mobile (KMM)",
      author: { "@id": `${SITE_URL}/#person` },
    }
  : null;

const blogPostUrl = blogPost
  ? lang === "ru"
    ? `${SITE_URL}/blog/ru/${slug}`
    : `${SITE_URL}/blog/${slug}`
  : null;

const blogPostingSchema = blogPost && blogPostUrl
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: blogPost.title,
      description: blogPost.summary,
      datePublished: blogPost.isoDate ?? blogPost.date,
      dateModified: blogPost.isoDateModified ?? blogPost.isoDate ?? blogPost.date,
      inLanguage: lang === "ru" ? "ru-RU" : "en-US",
      ...(typeof blogPost.wordCount === "number" && blogPost.wordCount > 0
        ? { wordCount: blogPost.wordCount }
        : {}),
      author: { "@id": `${SITE_URL}/#person` },
      keywords: blogPost.tags,
      articleSection: blogPost.category,
      url: blogPostUrl,
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": blogPostUrl,
      },
    }
  : null;
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(personSchema)}
/>
{
  websiteSchema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
  )
}
{
  blogPostingSchema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(blogPostingSchema)}
    />
  )
}
