---
import type { BlogPostData } from "@/types";

interface Props {
  isHomePage?: boolean;
  blogPost?: BlogPostData;
  slug?: string;
}

const { isHomePage = false, blogPost, slug } = Astro.props;

const SITE_URL = "https://po4yka.dev";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${SITE_URL}/#person`,
  name: "Nikita Pochaev",
  alternateName: "po4yka",
  url: SITE_URL,
  jobTitle: "Mobile Developer & Consultant",
  description:
    "Expert mobile engineer specializing in Android, iOS, and Kotlin Multiplatform. Recognized for architecting scalable KMP solutions with 60%+ code sharing, building release automation pipelines, and leading platform teams at scale. Deep expertise in Jetpack Compose, SwiftUI, MobileOps, and CI/CD optimization.",
  knowsAbout: [
    "Android",
    "iOS",
    "Kotlin Multiplatform",
    "MobileOps",
    "Jetpack Compose",
    "SwiftUI",
    "CI/CD",
    "Gradle",
    "Fastlane",
    "Mobile Architecture",
    "Release Automation",
  ],
  hasOccupation: {
    "@type": "Occupation",
    name: "Mobile Developer & Consultant",
    occupationLocation: { "@type": "Country", name: "Remote" },
    skills:
      "Kotlin, Swift, Jetpack Compose, SwiftUI, Kotlin Multiplatform, Gradle, Fastlane, CI/CD, Mobile Architecture",
  },
  makesOffer: {
    "@type": "Offer",
    itemOffered: {
      "@type": "Service",
      name: "Mobile Engineering Consulting",
      description:
        "KMP architecture design, MobileOps pipeline setup, Gradle build optimization, modularization strategy, and Compose/SwiftUI migration consulting for mobile teams.",
    },
  },
  sameAs: [
    "https://github.com/po4yka",
    "https://linkedin.com/in/po4yka",
    "https://t.me/po4yka",
  ],
};

const websiteSchema = isHomePage
  ? {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "Nikita Pochaev",
      url: SITE_URL,
      description:
        "Mobile Developer -- Android, iOS, Kotlin Multiplatform, MobileOps",
      author: { "@id": `${SITE_URL}/#person` },
    }
  : null;

function parseDate(dateStr: string): string {
  const months: Record<string, string> = {
    Jan: "01",
    Feb: "02",
    Mar: "03",
    Apr: "04",
    May: "05",
    Jun: "06",
    Jul: "07",
    Aug: "08",
    Sep: "09",
    Oct: "10",
    Nov: "11",
    Dec: "12",
  };
  const parts = dateStr.split(" ");
  if (parts.length === 2) {
    const month = months[parts[0]!];
    const year = parts[1];
    if (month && year) return `${year}-${month}-01`;
  }
  return dateStr;
}

const blogPostingSchema = blogPost
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: blogPost.title,
      description: blogPost.summary,
      datePublished: parseDate(blogPost.date),
      author: { "@id": `${SITE_URL}/#person` },
      keywords: blogPost.tags,
      url: `${SITE_URL}/blog/${slug}`,
    }
  : null;
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(personSchema)}
/>
{
  websiteSchema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
  )
}
{
  blogPostingSchema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(blogPostingSchema)}
    />
  )
}
