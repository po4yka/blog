---
import JsonLd from "@/components/JsonLd.astro";
import type { BlogPostData } from "@/types";

interface Props {
  title?: string;
  description?: string;
  isHomePage?: boolean;
  blogPost?: BlogPostData;
  blogSlug?: string;
  lang?: string;
  hasTranslation?: boolean;
}

const {
  title = "Nikita Pochaev — AI Engineer & Senior Mobile Developer",
  description = "AI Engineer and Senior Mobile Developer — Android, Kotlin Multiplatform Mobile (KMM). Shipping native mobile apps and integrating ML-powered features into production products.",
  isHomePage = false,
  blogPost,
  blogSlug,
  lang = "en",
  hasTranslation = false,
} = Astro.props;
---
<meta charset="UTF-8" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="preload" href="/fonts/jetbrains-mono-latin.woff2" as="font" type="font/woff2" crossorigin />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={new URL(Astro.url.pathname, "https://po4yka.dev").href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={blogPost ? "article" : "website"} />
<meta property="og:url" content={new URL(Astro.url.pathname, "https://po4yka.dev").href} />
<meta property="og:image" content="https://po4yka.dev/og-default.png" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content="https://po4yka.dev/og-default.png" />
<meta name="generator" content={Astro.generator} />
<link rel="sitemap" href="/sitemap-index.xml" />
{blogSlug && hasTranslation && lang === "en" && (
  <>
    <link rel="alternate" hreflang="en" href={`https://po4yka.dev/blog/${blogSlug}`} />
    <link rel="alternate" hreflang="ru" href={`https://po4yka.dev/blog/ru/${blogSlug}`} />
  </>
)}
{blogSlug && hasTranslation && lang === "ru" && (
  <>
    <link rel="alternate" hreflang="ru" href={`https://po4yka.dev/blog/ru/${blogSlug}`} />
    <link rel="alternate" hreflang="en" href={`https://po4yka.dev/blog/${blogSlug}`} />
  </>
)}
<JsonLd isHomePage={isHomePage} blogPost={blogPost} slug={blogSlug} />

{/* Analytics */}
{import.meta.env.PROD && (
  <script
    is:inline
    defer
    src="/m.js"
    data-website-id="00b2d486-bc06-431f-b5cf-80dce36ab698"
    data-host-url="/"
    data-do-not-track="true"
    data-domains="po4yka.dev"
  />
)}
