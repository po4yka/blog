---
import JsonLd from "@/components/JsonLd.astro";
import type { BlogPostData } from "@/types";

interface HreflangAlternate {
  hreflang: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  isHomePage?: boolean;
  blogPost?: BlogPostData;
  blogSlug?: string;
  lang?: string;
  hasTranslation?: boolean;
  /** Extra hreflang <link> tags injected by the caller (e.g. blog index pages). */
  hreflangAlternates?: HreflangAlternate[];
  /** When true, emits <meta name="robots" content="noindex,nofollow" />. */
  noindex?: boolean;
}

const {
  title = "Nikita Pochaev — AI Engineer & Senior Mobile Developer",
  description = "AI Engineer and Senior Mobile Developer — Android, Kotlin Multiplatform Mobile (KMM). Shipping native mobile apps and integrating ML-powered features into production products.",
  isHomePage = false,
  blogPost,
  blogSlug,
  lang = "en",
  hasTranslation = false,
  hreflangAlternates,
  noindex = false,
} = Astro.props;
---
<meta charset="UTF-8" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta name="theme-color" content="#0b0b0c" media="(prefers-color-scheme: dark)" />
<meta name="theme-color" content="#f5f3ee" media="(prefers-color-scheme: light)" />
<link rel="preload" href="/fonts/geist-latin.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/geist-mono-latin.woff2" as="font" type="font/woff2" crossorigin />
{lang === "en" && blogPost && (
  <link rel="preload" href="/fonts/piazzolla-latin.woff2" as="font" type="font/woff2" crossorigin />
)}
{lang === "ru" && blogPost && (
  <link rel="preload" href="/fonts/piazzolla-cyrillic.woff2" as="font" type="font/woff2" crossorigin />
)}
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex,nofollow" />}
<link rel="canonical" href={new URL(Astro.url.pathname, "https://po4yka.dev").href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={blogPost ? "article" : "website"} />
<meta property="og:url" content={new URL(Astro.url.pathname, "https://po4yka.dev").href} />
<meta property="og:site_name" content="po4yka.dev" />
<meta property="og:locale" content={lang === "ru" ? "ru_RU" : "en_US"} />
{(() => {
  const ogImage = blogPost && blogSlug
    ? `https://po4yka.dev/og/${lang}-${blogSlug}.png`
    : "https://po4yka.dev/og-default.png";
  return (
    <>
      <meta property="og:image" content={ogImage} />
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
      <meta property="og:image:alt" content={title} />
      {hasTranslation && (
        <meta property="og:locale:alternate" content={lang === "ru" ? "en_US" : "ru_RU"} />
      )}
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:site" content="@po4yka" />
      <meta name="twitter:creator" content="@po4yka" />
      <meta name="twitter:title" content={title} />
      <meta name="twitter:description" content={description} />
      <meta name="twitter:image" content={ogImage} />
    </>
  );
})()}
<meta name="generator" content={Astro.generator} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" hreflang="en" title="po4yka.dev — English posts" href="https://po4yka.dev/rss.xml" />
<link rel="alternate" type="application/rss+xml" hreflang="ru" title="po4yka.dev — Русские записи" href="https://po4yka.dev/rss.ru.xml" />
{/*
  Hreflang strategy for blog posts:
  - If a translation exists, emit both language variants plus x-default -> the English URL.
  - If only this language exists, emit self-referential hreflang plus x-default pointing at
    the canonical post URL, telling crawlers this is the sole available language.
*/}
{hreflangAlternates && hreflangAlternates.map((alt) => (
  <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
))}
{!blogSlug && !hreflangAlternates && lang === "en" && (
  <>
    <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname, "https://po4yka.dev").href} />
    <link rel="alternate" hreflang="x-default" href={new URL(Astro.url.pathname, "https://po4yka.dev").href} />
  </>
)}
{blogSlug && lang === "en" && (
  <>
    <link rel="alternate" hreflang="en" href={`https://po4yka.dev/blog/${blogSlug}`} />
    {hasTranslation && (
      <link rel="alternate" hreflang="ru" href={`https://po4yka.dev/blog/ru/${blogSlug}`} />
    )}
    <link rel="alternate" hreflang="x-default" href={`https://po4yka.dev/blog/${blogSlug}`} />
  </>
)}
{blogSlug && lang === "ru" && (
  <>
    <link rel="alternate" hreflang="ru" href={`https://po4yka.dev/blog/ru/${blogSlug}`} />
    {hasTranslation && (
      <link rel="alternate" hreflang="en" href={`https://po4yka.dev/blog/${blogSlug}`} />
    )}
    <link rel="alternate" hreflang="x-default" href={hasTranslation
      ? `https://po4yka.dev/blog/${blogSlug}`
      : `https://po4yka.dev/blog/ru/${blogSlug}`} />
  </>
)}
<JsonLd isHomePage={isHomePage} blogPost={blogPost} slug={blogSlug} lang={lang} />

{/* Analytics */}
{import.meta.env.PROD && (
  <script
    is:inline
    defer
    src="/m.js"
    data-website-id="00b2d486-bc06-431f-b5cf-80dce36ab698"
    data-host-url="/"
    data-do-not-track="true"
    data-domains="po4yka.dev"
  />
)}
