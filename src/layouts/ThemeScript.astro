---
// Inline script that runs synchronously before paint to prevent FOUC.
// Reads theme preference from localStorage and applies .dark/.light to <html>.
const { nonce } = Astro.locals;
---
<script is:inline nonce={nonce}>
(function() {
  try {
    var raw = localStorage.getItem('site_preferences');
    var stored = raw ? JSON.parse(raw) : {};
    var prefs = stored.state || stored;
    var theme = prefs.theme || 'system';
    var resolved = theme === 'system'
      ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
      : theme;
    document.documentElement.classList.add(resolved);
    if (prefs.reduceMotion) document.documentElement.classList.add('reduce-motion');
    if (prefs.fontSize) {
      var sizes = { compact: '15px', 'default': '16px', large: '17px' };
      var size = sizes[prefs.fontSize];
      if (size) document.documentElement.style.setProperty('--font-size', size);
    }
    if (prefs.reduceMotion) {
      document.documentElement.style.setProperty('--motion-duration-scale', '0');
    }
    // BaseHead's two static theme-color tags only track OS preference via
    // `media`. An explicit light/dark override (not "system") needs its own
    // non-media tag kept in sync so the mobile browser chrome matches it too.
    var themeColorMeta = document.querySelector('meta[name="theme-color"]:not([media])');
    if (!themeColorMeta) {
      themeColorMeta = document.createElement('meta');
      themeColorMeta.setAttribute('name', 'theme-color');
      document.head.appendChild(themeColorMeta);
    }
    themeColorMeta.setAttribute('content', resolved === 'dark' ? '#0b0b0c' : '#f5f3ee');
  } catch(e) {}
})();
</script>
<script>
  // Re-apply theme after View Transition DOM swap to prevent flash
  function applyThemeFromStorage() {
    try {
      const raw = localStorage.getItem("site_preferences");
      if (!raw) return;
      const stored = JSON.parse(raw);
      const prefs = stored.state || stored;
      const theme = prefs.theme || "system";
      const resolved = theme === "system"
        ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
        : theme;
      document.documentElement.classList.toggle("dark", resolved === "dark");
      document.documentElement.classList.toggle("light", resolved === "light");
      document.documentElement.classList.toggle("reduce-motion", !!prefs.reduceMotion);
      document.documentElement.style.setProperty(
        "--motion-duration-scale",
        prefs.reduceMotion ? "0" : "1"
      );
      let themeColorMeta = document.querySelector('meta[name="theme-color"]:not([media])');
      if (!themeColorMeta) {
        themeColorMeta = document.createElement("meta");
        themeColorMeta.setAttribute("name", "theme-color");
        document.head.appendChild(themeColorMeta);
      }
      themeColorMeta.setAttribute("content", resolved === "dark" ? "#0b0b0c" : "#f5f3ee");
    } catch {}
  }
  document.addEventListener("astro:after-swap", applyThemeFromStorage);
</script>
