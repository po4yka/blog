---
import { ClientRouter } from "astro:transitions";
import { fade } from "astro:transitions";
import BaseHead from "./BaseHead.astro";
import ThemeScript from "./ThemeScript.astro";
import { Nav } from "@/components/Nav";
import { Footer } from "@/components/Footer";
import { KeyboardShortcuts } from "@/components/KeyboardShortcuts";
import "@/styles/index.css";
import type { BlogPostData } from "@/types";

interface HreflangAlternate {
  hreflang: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  isHomePage?: boolean;
  blogPost?: BlogPostData;
  blogSlug?: string;
  lang?: string;
  hasTranslation?: boolean;
  translationSlug?: string;
  hreflangAlternates?: HreflangAlternate[];
  noindex?: boolean;
}

const { title, description, isHomePage, blogPost, blogSlug, lang = "en", hasTranslation = false, translationSlug, hreflangAlternates, noindex = false } = Astro.props;
const { pathname } = Astro.url;
const { nonce } = Astro.locals;
---
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} isHomePage={isHomePage} blogPost={blogPost} blogSlug={blogSlug} lang={lang} hasTranslation={hasTranslation} hreflangAlternates={hreflangAlternates} noindex={noindex} />
    <ThemeScript />
    <script nonce={nonce} is:inline>
      // Sync <picture data-theme-aware> source media queries with the site's
      // manual theme override. Installs once at <head> parse time — before any
      // BlogFigure picture is encountered — so per-figure FOUC scripts aren't
      // needed.
      (() => {
        const sync = () => {
          const siteDark = document.documentElement.classList.contains("dark");
          document.querySelectorAll("picture[data-theme-aware]").forEach((picture) => {
            picture.querySelectorAll("source[data-theme]").forEach((src) => {
              const theme = src.dataset.theme;
              const viewport = src.dataset.viewport;
              if (theme !== "dark" && theme !== "light") return;
              const matches = theme === "dark" ? siteDark : !siteDark;
              src.setAttribute(
                "media",
                matches ? (viewport === "mobile" ? "(max-width: 640px)" : "all") : "not all",
              );
            });
            picture.dataset.themeSynced = "1";
          });
        };
        new MutationObserver(sync).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
        document.addEventListener("astro:after-swap", sync);
        // Run again at DOMContentLoaded for figures that hadn't been parsed yet
        // when this script ran during <head>.
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", sync);
        } else {
          sync();
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-foreground focus:text-background focus:rounded-[2px] focus:outline focus:outline-2 focus:outline-offset-2" style="outline-color: var(--emphasis)">
      Skip to main content
    </a>
    <div class="min-h-screen bg-background text-foreground transition-colors duration-300">
      <Nav client:idle pathname={pathname} lang={lang} translationSlug={translationSlug} transition:persist />
      <main
        id="main-content"
        tabindex="-1"
        class="max-w-[1160px] mx-auto px-6 md:px-10 lg:px-12 pt-16 pb-20"
        transition:animate={fade({ duration: '0.2s' })}
      >
        <slot />
      </main>
      <Footer client:idle transition:persist />
      <KeyboardShortcuts client:idle transition:persist />
    </div>
    <script>
      // WebMCP bootstrap: expose site-scoped tools to in-browser AI agents.
      // No-ops in browsers that do not implement navigator.modelContext.
      import("@/lib/webmcp").then((m) => m.registerWebMCP()).catch(() => {});
    </script>
    <script>
      // Sync <html lang> with stored locale preference (for non-blog pages)
      function syncLang() {
        try {
          const stored = JSON.parse(localStorage.getItem('site_preferences') || '{}');
          const prefs = stored.state || stored;
          if (prefs.locale && prefs.locale !== document.documentElement.lang) {
            // Only override for non-blog-ru pages (blog/ru pages set lang="ru" server-side)
            if (!window.location.pathname.startsWith('/blog/ru')) {
              document.documentElement.lang = prefs.locale;
            }
          }
        } catch { /* ignore */ }
      }
      syncLang();
      document.addEventListener('astro:after-swap', syncLang);
    </script>
  </body>
</html>
