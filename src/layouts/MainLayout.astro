---
import { ClientRouter } from "astro:transitions";
import { fade } from "astro:transitions";
import BaseHead from "./BaseHead.astro";
import ThemeScript from "./ThemeScript.astro";
import { Nav } from "@/components/Nav";
import { Footer } from "@/components/Footer";
import { KeyboardShortcuts } from "@/components/KeyboardShortcuts";
import "@/styles/index.css";
import type { BlogPostData } from "@/types";

interface Props {
  title?: string;
  description?: string;
  isHomePage?: boolean;
  blogPost?: BlogPostData;
  blogSlug?: string;
}

const { title, description, isHomePage, blogPost, blogSlug } = Astro.props;
const { pathname } = Astro.url;
---
<html lang="en">
  <head>
    <BaseHead title={title} description={description} isHomePage={isHomePage} blogPost={blogPost} blogSlug={blogSlug} />
    <ThemeScript />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-accent-foreground focus:rounded-md focus:outline-none">
      Skip to main content
    </a>
    <div
      class="min-h-screen bg-background text-foreground transition-colors duration-300"
      style="font-family: 'JetBrains Mono', 'Cascadia Code', 'Fira Code', 'Monaco', 'Courier New', monospace;"
    >
      <Nav client:load pathname={pathname} transition:persist />
      <main
        id="main-content"
        class="max-w-[1080px] mx-auto px-6 md:px-10 lg:px-12 pt-16 pb-20"
        transition:animate={fade({ duration: '0.2s' })}
      >
        <slot />
      </main>
      <Footer client:idle transition:persist />
      <KeyboardShortcuts client:idle transition:persist />
      <div
        id="cursor-glow"
        class="fixed inset-0 pointer-events-none"
        style="z-index:40;opacity:0;transition:opacity 0.3s ease;background:radial-gradient(300px circle at var(--cursor-x,-999px) var(--cursor-y,-999px),rgba(145,132,247,0.06) 0%,transparent 100%)"
        transition:persist
      ></div>
    </div>
    <script>
      function initCursorGlow() {
        const el = document.getElementById('cursor-glow');
        if (!el) return;
        const stored = (() => { try { return JSON.parse(localStorage.getItem('site_preferences') || '{}'); } catch { return {}; } })();
        const prefs = stored.state || stored;
        if (prefs.reduceMotion) { el.style.display = 'none'; return; }
        document.addEventListener('mousemove', (e) => {
          el.style.setProperty('--cursor-x', e.clientX + 'px');
          el.style.setProperty('--cursor-y', e.clientY + 'px');
          el.style.opacity = '1';
        }, { passive: true });
        document.addEventListener('mouseleave', () => { el.style.opacity = '0'; });
      }
      initCursorGlow();
      document.addEventListener('astro:page-load', initCursorGlow);
    </script>
  </body>
</html>
