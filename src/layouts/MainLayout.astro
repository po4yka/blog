---
import { ClientRouter } from "astro:transitions";
import { fade } from "astro:transitions";
import BaseHead from "./BaseHead.astro";
import ThemeScript from "./ThemeScript.astro";
import { Nav } from "@/components/Nav";
import { Footer } from "@/components/Footer";
import { KeyboardShortcuts } from "@/components/KeyboardShortcuts";
import { CursorGlow } from "@/components/CursorGlow";
import "@/styles/index.css";

interface BlogPostData {
  title: string;
  date: string;
  summary: string;
  tags: string[];
  category: string;
}

interface Props {
  title?: string;
  description?: string;
  isHomePage?: boolean;
  blogPost?: BlogPostData;
  blogSlug?: string;
}

const { title, description, isHomePage, blogPost, blogSlug } = Astro.props;
const { pathname } = Astro.url;
---
<html lang="en">
  <head>
    <BaseHead title={title} description={description} isHomePage={isHomePage} blogPost={blogPost} blogSlug={blogSlug} />
    <ThemeScript />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-accent-foreground focus:rounded-md focus:outline-none">
      Skip to main content
    </a>
    <div
      class="min-h-screen bg-background text-foreground transition-colors duration-300"
      style="font-family: 'JetBrains Mono', monospace;"
    >
      <Nav client:load pathname={pathname} transition:persist />
      <main
        id="main-content"
        class="max-w-[1080px] mx-auto px-6 md:px-10 lg:px-12 pt-16 pb-20"
        transition:animate={fade({ duration: '0.2s' })}
      >
        <slot />
      </main>
      <Footer client:load transition:persist />
      <KeyboardShortcuts client:load transition:persist />
      <CursorGlow client:load transition:persist />
    </div>
  </body>
</html>
