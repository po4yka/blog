---
import MainLayout from "@/layouts/MainLayout.astro";
import { Hero } from "@/components/Hero";
import { About } from "@/components/About";
import { Links } from "@/components/Links";
import { Projects } from "@/components/Projects";
import { Experience } from "@/components/Experience";
import { BlogPreview } from "@/components/BlogPreview";
import { RealGitLog } from "@/components/MobileTerminal";
import {
  OpenSourcePanel,
  ActivityCalendar,
  BlogStatsPanel,
} from "@/components/Decorations";
---
<MainLayout isHomePage>
  <div class="space-y-8 md:space-y-14">
    <div data-section-name="hero">
      <Hero client:load />
    </div>
    <div class="section-reveal" data-section-name="about" style="transition-delay:0.1s">
      <About client:visible />
    </div>

    <div class="section-reveal" data-section-name="links" style="transition-delay:0.2s">
      <Links client:visible />
    </div>

    <div data-section-name="projects">
      <Projects client:visible />
    </div>

    <!-- projects → open source repos from GitHub (real data) -->
    <div data-section-name="open-source">
      <OpenSourcePanel client:visible delay={0.05} />
    </div>

    <div data-section-name="experience">
      <Experience client:visible />
    </div>

    <!-- GitHub activity calendar (real data) -->
    <div data-section-name="activity-calendar">
      <ActivityCalendar client:visible delay={0.05} />
    </div>

    <!-- Real git commits from GitHub -->
    <div data-section-name="git-log">
      <RealGitLog client:visible delay={0.05} />
    </div>

    <div data-section-name="blog">
      <BlogPreview client:visible />
    </div>

    <!-- blog → blog stats (decorative) -->
    <div data-section-name="blog-stats">
      <BlogStatsPanel client:visible delay={0.05} />
    </div>
  </div>

  <style>
    .section-reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .section-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* System preference */
    @media (prefers-reduced-motion: reduce) {
      .section-reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }

    /* In-app preference (settingsStore.reduceMotion toggles .reduce-motion
       on <html> — see src/stores/settingsStore.ts applyToDOM). */
    :global(html.reduce-motion) .section-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }

    /* Skip rendering for off-screen sections until scrolled into view.
       Only sections that always render non-empty content — empty-prone
       API-driven sections (open-source, activity-calendar, git-log)
       would otherwise reserve a 300px placeholder that collapses to
       0px once the component hydrates and returns null, producing a
       visible gap while the user is scrolling. */
    [data-section-name="experience"],
    [data-section-name="blog"],
    [data-section-name="blog-stats"] {
      content-visibility: auto;
      contain-intrinsic-size: auto 300px;
    }

    /* Collapse empty-prone API-driven section wrappers (open-source,
       activity-calendar, git-log) when the island has no content yet.
       Without this, each wrapper keeps its Tailwind space-y-14 margin
       and produces a phantom 56 px gap. `:has()` and `:empty` are
       universally supported in modern browsers (Chrome 105+, Safari
       15.4+, Firefox 121+). When the island hydrates and renders
       content, `:empty` stops matching and the section reappears. */
    [data-section-name]:has(> astro-island:empty) {
      display: none;
    }
  </style>

  <script>
    import "@/stores/activitySensor";

    function initSectionReveal() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll(".section-reveal").forEach((el) => observer.observe(el));
    }

    // Run on initial load and on View Transition navigations
    initSectionReveal();
    document.addEventListener("astro:page-load", initSectionReveal);
  </script>
</MainLayout>
