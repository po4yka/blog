---
import MainLayout from "@/layouts/MainLayout.astro";
import { Hero } from "@/components/Hero";
import { About } from "@/components/About";
import { Links } from "@/components/Links";
import { Projects } from "@/components/Projects";
import { Experience } from "@/components/Experience";
import { BlogPreview } from "@/components/BlogPreview";
import { UptimeStrip, SystemBottomBar, MemoryGrid } from "@/components/Decorations";
import {
  AdbDevices,
  GradleBuild,
  XcodeSimulators,
  FastlaneDeploy,
  GitLog,
  AdbLogcat,
  SwiftPackageResolve,
  KtlintCheck,
} from "@/components/MobileTerminal";
---
<MainLayout isHomePage>
  <div class="space-y-8 md:space-y-14">
    <div class="section-reveal" data-section-name="hero">
      <Hero client:visible />
    </div>
    <div class="section-reveal" data-section-name="about" style="transition-delay:0.1s">
      <About client:visible />
    </div>

    <!-- Mobile dev: connected devices -->
    <div class="section-reveal" data-section-name="adb-devices" style="transition-delay:0.15s">
      <AdbDevices client:visible delay={0.05} />
    </div>

    <div class="section-reveal" data-section-name="links" style="transition-delay:0.2s">
      <Links client:visible />
    </div>

    <!-- Decorative system metrics strip -->
    <div data-section-name="uptime">
      <UptimeStrip client:visible delay={0.05} />
    </div>

    <!-- Mobile dev: Gradle build output -->
    <div data-section-name="gradle-build">
      <GradleBuild client:visible delay={0.05} />
    </div>

    <div data-section-name="projects">
      <Projects client:visible />
    </div>

    <!-- Mobile dev: iOS simulators + SPM resolve side-by-side on desktop -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6" data-section-name="xcode-spm">
      <XcodeSimulators client:visible delay={0.05} />
      <SwiftPackageResolve client:visible delay={0.1} />
    </div>

    <!-- Decorative memory + disk panels -->
    <div data-section-name="memory">
      <MemoryGrid client:visible delay={0.05} />
    </div>

    <div data-section-name="experience">
      <Experience client:visible />
    </div>

    <!-- Mobile dev: git log + lint check -->
    <div data-section-name="git-log">
      <GitLog client:visible delay={0.05} />
    </div>
    <div data-section-name="ktlint">
      <KtlintCheck client:visible delay={0.05} />
    </div>

    <div data-section-name="blog">
      <BlogPreview client:visible />
    </div>

    <!-- Mobile dev: logcat + fastlane deploy -->
    <div data-section-name="logcat">
      <AdbLogcat client:visible delay={0.05} />
    </div>
    <div data-section-name="fastlane">
      <FastlaneDeploy client:visible delay={0.05} />
    </div>

    <!-- Bottom system bar -->
    <div data-section-name="system-bar">
      <SystemBottomBar client:visible delay={0.05} />
    </div>
  </div>

  <style>
    .section-reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .section-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    import "@/stores/activitySensor";

    function initSectionReveal() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll(".section-reveal").forEach((el) => observer.observe(el));
    }

    // Run on initial load and on View Transition navigations
    initSectionReveal();
    document.addEventListener("astro:page-load", initSectionReveal);
  </script>
</MainLayout>
