---
import MainLayout from "@/layouts/MainLayout.astro";
import { Hero } from "@/components/Hero";
import { About } from "@/components/About";
import { Links } from "@/components/Links";
import { Projects } from "@/components/Projects";
import { Experience } from "@/components/Experience";
import { BlogPreview } from "@/components/BlogPreview";
import { UptimeStrip, SystemBottomBar, MemoryGrid } from "@/components/Decorations";
import {
  AdbDevices,
  GradleBuild,
  XcodeSimulators,
  FastlaneDeploy,
  GitLog,
  AdbLogcat,
  SwiftPackageResolve,
  KtlintCheck,
} from "@/components/MobileTerminal";
---
<MainLayout>
  <div class="space-y-14">
    <div class="section-reveal">
      <Hero client:visible />
    </div>
    <div class="section-reveal" style="transition-delay:0.1s">
      <About client:visible />
    </div>

    <!-- Mobile dev: connected devices -->
    <div class="section-reveal" style="transition-delay:0.15s">
      <AdbDevices client:visible delay={0.05} />
    </div>

    <div class="section-reveal" style="transition-delay:0.2s">
      <Links client:visible />
    </div>

    <!-- Decorative system metrics strip -->
    <UptimeStrip client:visible delay={0.05} />

    <!-- Mobile dev: Gradle build output -->
    <GradleBuild client:visible delay={0.05} />

    <Projects client:visible />

    <!-- Mobile dev: iOS simulators + SPM resolve side-by-side on desktop -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <XcodeSimulators client:visible delay={0.05} />
      <SwiftPackageResolve client:visible delay={0.1} />
    </div>

    <!-- Decorative memory + disk panels -->
    <MemoryGrid client:visible delay={0.05} />

    <Experience client:visible />

    <!-- Mobile dev: git log + lint check -->
    <GitLog client:visible delay={0.05} />
    <KtlintCheck client:visible delay={0.05} />

    <BlogPreview client:visible />

    <!-- Mobile dev: logcat + fastlane deploy -->
    <AdbLogcat client:visible delay={0.05} />
    <FastlaneDeploy client:visible delay={0.05} />

    <!-- Bottom system bar -->
    <SystemBottomBar client:visible delay={0.05} />
  </div>

  <style>
    .section-reveal {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .section-reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    function initSectionReveal() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll(".section-reveal").forEach((el) => observer.observe(el));
    }

    // Run on initial load and on View Transition navigations
    initSectionReveal();
    document.addEventListener("astro:page-load", initSectionReveal);
  </script>
</MainLayout>
