---
import { getCollection } from "astro:content";
import MainLayout from "@/layouts/MainLayout.astro";
import { BlogListIsland } from "@/components/BlogListIsland";
import { parsePostId } from "@/lib/i18n";

const allPosts = await getCollection("blog");

// Filter to English posts only
const posts = allPosts.filter((p) => parsePostId(p.id).lang === "en");

// Sort by date descending (newest first)
posts.sort((a, b) => {
  const dateA = new Date(a.data.date);
  const dateB = new Date(b.data.date);
  return dateB.getTime() - dateA.getTime();
});

const serializedPosts = posts.map((p) => ({
  slug: parsePostId(p.id).baseSlug,
  ...p.data,
  // build-time estimate from the raw MDX body; same 220 wpm rate the post
  // page uses for its client-side fallback
  readingTime:
    p.data.readingTime ?? Math.max(1, Math.round((p.body ?? "").trim().split(/\s+/).length / 220)),
}));

const categories = [
  "All",
  ...new Set(posts.map((p) => p.data.category)),
];
const blogIndexHreflang = [
  { hreflang: "en", href: "https://po4yka.dev/blog" },
  { hreflang: "ru", href: "https://po4yka.dev/blog/ru" },
  { hreflang: "x-default", href: "https://po4yka.dev/blog" },
];
---
<MainLayout title="Blog — Nikita Pochaev" description="Technical writing on Android, Kotlin Multiplatform, MobileOps, and AI integration — by Nikita Pochaev, mobile engineer." hreflangAlternates={blogIndexHreflang}>
  <BlogListIsland client:load posts={serializedPosts} categories={categories} />
</MainLayout>
