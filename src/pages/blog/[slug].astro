---
import { getCollection, render } from "astro:content";
import { slide } from "astro:transitions";
import MainLayout from "@/layouts/MainLayout.astro";
import { BlogPostIsland } from "@/components/BlogPostIsland";
import { buildBlogStaticPaths } from "@/lib/blogStaticPaths";
import { parsePostId } from "@/lib/i18n";
import "katex/dist/katex.min.css";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  return buildBlogStaticPaths(allPosts, "en");
}

const { post, prev, next, related, hasTranslation } = Astro.props;
const baseSlug = parsePostId(post.id).baseSlug;
const { Content } = await render(post);
// Pull the generated ISO date from blogData so the client gets a parseable timestamp.
import { blogPosts } from "@/data/blogData";
const generated = blogPosts.find((p) => p.slug === baseSlug && p.lang === "en");
const blogData = {
  ...post.data,
  isoDate: generated?.isoDate,
  isoDateModified: generated?.isoDateModified,
  wordCount: generated?.wordCount,
};
---
<MainLayout title={`${post.data.title} — Nikita Pochaev`} description={post.data.summary} blogPost={blogData} blogSlug={baseSlug} hasTranslation={hasTranslation} translationSlug={hasTranslation ? baseSlug : undefined}>
  <div transition:name="blog-content" transition:animate={slide({ duration: '0.3s' })}>
    <BlogPostIsland
      client:idle
      post={blogData}
      slug={baseSlug}
      prev={prev}
      next={next}
      related={related}
      lang="en"
    >
      <Content />
    </BlogPostIsland>
  </div>
</MainLayout>
