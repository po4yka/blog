---
import { getCollection } from "astro:content";
import MainLayout from "@/layouts/MainLayout.astro";
import { BlogListIsland } from "@/components/BlogListIsland";
import { parsePostId } from "@/lib/i18n";

const allPosts = await getCollection("blog");

// Filter to Russian posts only
const posts = allPosts.filter((p) => parsePostId(p.id).lang === "ru");

// Sort by date descending (newest first)
posts.sort((a, b) => {
  const dateA = new Date(a.data.date);
  const dateB = new Date(b.data.date);
  return dateB.getTime() - dateA.getTime();
});

const serializedPosts = posts.map((p) => ({
  slug: parsePostId(p.id).baseSlug,
  ...p.data,
}));

const categories = [
  "All",
  ...new Set(posts.map((p) => p.data.category)),
];
---
<MainLayout title="Blog — Nikita Pochaev" lang="ru">
  <div transition:name="blog-content" class="island-loader">
    <div class="skeleton-window island-skeleton">
      <div class="skeleton" style="height: 28px; width: 40%; margin-bottom: 16px;"></div>
      <div class="skeleton" style="height: 14px; width: 70%; margin-bottom: 12px;"></div>
      <div class="skeleton" style="height: 14px; width: 55%; margin-bottom: 24px;"></div>
      <div class="skeleton-window" style="box-shadow: none; padding: 16px;">
        <div class="skeleton" style="height: 32px; margin-bottom: 16px;"></div>
        <div class="skeleton" style="height: 48px; margin-bottom: 12px;"></div>
        <div class="skeleton" style="height: 48px; margin-bottom: 12px;"></div>
        <div class="skeleton" style="height: 48px;"></div>
      </div>
    </div>
    <BlogListIsland client:idle posts={serializedPosts} categories={categories} lang="ru" />
  </div>
</MainLayout>
