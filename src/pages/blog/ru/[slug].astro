---
import { getCollection, render } from "astro:content";
import { slide } from "astro:transitions";
import MainLayout from "@/layouts/MainLayout.astro";
import { BlogPostIsland } from "@/components/BlogPostIsland";
import { parsePostId } from "@/lib/i18n";
import "katex/dist/katex.min.css";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");

  // Separate by language
  const ruPosts = allPosts.filter((p) => parsePostId(p.id).lang === "ru");
  const enSlugs = new Set(
    allPosts.filter((p) => parsePostId(p.id).lang === "en").map((p) => parsePostId(p.id).baseSlug),
  );

  // Sort Russian posts by date descending
  ruPosts.sort((a, b) => {
    const dateA = new Date(a.data.date);
    const dateB = new Date(b.data.date);
    return dateB.getTime() - dateA.getTime();
  });

  return ruPosts.map((post, idx) => {
    const baseSlug = parsePostId(post.id).baseSlug;
    const prevPost = idx > 0 ? ruPosts[idx - 1]! : null;
    const nextPost = idx < ruPosts.length - 1 ? ruPosts[idx + 1]! : null;

    // Compute related: same lang, different slug, ranked by tag overlap desc, then recency.
    const currentTags = new Set(post.data.tags ?? []);
    const candidates = ruPosts
      .filter((p) => parsePostId(p.id).baseSlug !== baseSlug)
      .map((p) => {
        const tags: string[] = p.data.tags ?? [];
        const overlap = tags.reduce((n, t) => n + (currentTags.has(t) ? 1 : 0), 0);
        const sameCategory = p.data.category === post.data.category ? 1 : 0;
        return { p, overlap, sameCategory };
      });
    candidates.sort((a, b) => {
      if (b.overlap !== a.overlap) return b.overlap - a.overlap;
      if (b.sameCategory !== a.sameCategory) return b.sameCategory - a.sameCategory;
      return new Date(b.p.data.date).getTime() - new Date(a.p.data.date).getTime();
    });
    const related = candidates.slice(0, 3).map(({ p }) => ({
      slug: parsePostId(p.id).baseSlug,
      title: p.data.title,
      date: p.data.date,
      isoDate: p.data.isoDate,
      category: p.data.category,
      summary: p.data.summary,
    }));

    return {
      params: { slug: baseSlug },
      props: {
        post,
        prev: prevPost
          ? {
              slug: parsePostId(prevPost.id).baseSlug,
              title: prevPost.data.title,
              date: prevPost.data.date,
            }
          : null,
        next: nextPost
          ? {
              slug: parsePostId(nextPost.id).baseSlug,
              title: nextPost.data.title,
              date: nextPost.data.date,
            }
          : null,
        related,
        hasTranslation: enSlugs.has(baseSlug),
      },
    };
  });
}

const { post, prev, next, related, hasTranslation } = Astro.props;
const baseSlug = parsePostId(post.id).baseSlug;
const { Content } = await render(post);
// Pull the generated ISO date from blogData so the client gets a parseable timestamp.
import { blogPosts } from "@/data/blogData";
const generated = blogPosts.find((p) => p.slug === baseSlug && p.lang === "ru");
const blogData = {
  ...post.data,
  isoDate: generated?.isoDate,
  isoDateModified: generated?.isoDateModified,
  wordCount: generated?.wordCount,
};
---
<MainLayout title={`${post.data.title} — Nikita Pochaev`} description={post.data.summary} blogPost={blogData} blogSlug={baseSlug} lang="ru" hasTranslation={hasTranslation} translationSlug={hasTranslation ? baseSlug : undefined}>
  <div transition:name="blog-content" transition:animate={slide({ duration: '0.3s' })}>
    <BlogPostIsland
      client:idle
      post={blogData}
      slug={baseSlug}
      prev={prev}
      next={next}
      related={related}
      lang="ru"
    >
      <Content />
    </BlogPostIsland>
  </div>
</MainLayout>
