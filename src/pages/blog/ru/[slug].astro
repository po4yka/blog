---
import { getCollection, render } from "astro:content";
import { slide } from "astro:transitions";
import MainLayout from "@/layouts/MainLayout.astro";
import { BlogPostIsland } from "@/components/BlogPostIsland";
import { parsePostId } from "@/lib/i18n";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");

  // Separate by language
  const ruPosts = allPosts.filter((p) => parsePostId(p.id).lang === "ru");
  const enSlugs = new Set(
    allPosts.filter((p) => parsePostId(p.id).lang === "en").map((p) => parsePostId(p.id).baseSlug),
  );

  // Sort Russian posts by date descending
  ruPosts.sort((a, b) => {
    const dateA = new Date(a.data.date);
    const dateB = new Date(b.data.date);
    return dateB.getTime() - dateA.getTime();
  });

  return ruPosts.map((post, idx) => {
    const baseSlug = parsePostId(post.id).baseSlug;
    const prevPost = idx > 0 ? ruPosts[idx - 1]! : null;
    const nextPost = idx < ruPosts.length - 1 ? ruPosts[idx + 1]! : null;
    return {
      params: { slug: baseSlug },
      props: {
        post,
        prev: prevPost ? { slug: parsePostId(prevPost.id).baseSlug, title: prevPost.data.title } : null,
        next: nextPost ? { slug: parsePostId(nextPost.id).baseSlug, title: nextPost.data.title } : null,
        hasTranslation: enSlugs.has(baseSlug),
      },
    };
  });
}

const { post, prev, next, hasTranslation } = Astro.props;
const baseSlug = parsePostId(post.id).baseSlug;
const { Content } = await render(post);
---
<MainLayout title={`${post.data.title} — Nikita Pochaev`} description={post.data.summary} blogPost={post.data} blogSlug={baseSlug} lang="ru" hasTranslation={hasTranslation}>
  <div transition:name="blog-content" transition:animate={slide({ duration: '0.3s' })}>
    <BlogPostIsland
      client:idle
      post={post.data}
      slug={baseSlug}
      prev={prev}
      next={next}
      lang="ru"
      translationSlug={hasTranslation ? baseSlug : undefined}
    >
      <Content />
    </BlogPostIsland>
  </div>
</MainLayout>
