{
  "name": "blog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "tsx scripts/generate-all-data.ts && astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:blog": "tsx scripts/generate-blog-data.ts",
    "generate:all": "tsx scripts/generate-all-data.ts",
    "scan:complexity": "tsx scripts/scan-complexity.ts",
    "validate:blog": "tsx scripts/validate-blog-sync.ts",
    "validate:skills": "bash scripts/validate-codex-skills.sh",
    "validate:all": "tsx scripts/validate-all-sync.ts",
    "setup:passkey": "tsx scripts/setup-passkey.ts",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "lighthouse": "lhci autorun",
    "prepare": "simple-git-hooks",
    "indexnow": "node scripts/indexnow-submit.mjs"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx commitlint --edit $1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --no-warn-ignored"
    ]
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@radix-ui/react-dialog": "^1.1.16",
    "@resvg/resvg-js": "^2.6.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@tanstack/react-query": "^5.101.2",
    "astro": "^7.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "satori": "^0.26.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "vite": "$vite",
    "esbuild": ">=0.28.1",
    "tmp": ">=0.2.6",
    "defu": ">=6.1.5",
    "basic-ftp": "6.0.1",
    "ws": ">=8.21.0",
    "qs": ">=6.15.2",
    "uuid": ">=11.1.1",
    "undici": "^7.28.0",
    "@babel/core": "^7.29.6",
    "js-yaml@^4.0.0": "4.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "lint-staged": "^17.0.8",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.35.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
